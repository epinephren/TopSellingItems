<Project Sdk="Dalamud.NET.Sdk/14.0.1">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>TopSellingItems</AssemblyName>
    <RootNamespace>TopSellingItems</RootNamespace>
    <Version>1.0.0.1</Version>
    <Description>Shows the most sold FFXIV items using Universalis dailySaleVelocity.</Description>
  </PropertyGroup>

  <ItemGroup>
    <None Include="TopSellingItems.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Content Include="pluginmaster.json" />
  </ItemGroup>
</Project>
